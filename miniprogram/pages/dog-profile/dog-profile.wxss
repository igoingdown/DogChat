.dog-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx;
}

.dog-avatar-large {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: #e0e0e0;
  margin-bottom: 20rpx;
}

.dog-name-large {
  font-size: 36rpx;
  font-weight: 500;
  color: #333;
}

.dog-meta {
  font-size: 26rpx;
  color: #999;
  margin-top: 12rpx;
}

.action-list {
  margin-top: 20rpx;
}

.action-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 16rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.action-text {
  font-size: 30rpx;
  color: #333;
}

.arrow {
  font-size: 36rpx;
  color: #ccc;
}
