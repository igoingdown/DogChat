.form-item {
  margin-bottom: 32rpx;
}

.label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
  display: block;
}

.picker {
  background: #f5f5f5;
  padding: 20rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
}

.input {
  background: #f5f5f5;
  padding: 20rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.friend-select {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.friend-tag {
  display: flex;
  align-items: center;
  padding: 12rpx 20rpx;
  background: #f5f5f5;
  border-radius: 32rpx;
  border: 2rpx solid transparent;
}

.friend-tag.selected {
  background: #e6f7e6;
  border-color: #07c160;
}

.tag-avatar {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  margin-right: 10rpx;
}

.tag-name {
  font-size: 26rpx;
  color: #333;
}

.no-friends {
  padding: 20rpx;
  color: #999;
  font-size: 26rpx;
}

.save-btn {
  margin-top: 40rpx;
  background: #ccc;
  color: #fff;
  padding: 24rpx;
  border-radius: 12rpx;
  text-align: center;
  font-size: 32rpx;
}

.save-btn.active {
  background: #07c160;
}

.detail-header {
  margin-bottom: 24rpx;
}

.detail-body {
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.detail-row {
  margin-bottom: 16rpx;
}

.detail-label {
  font-size: 26rpx;
  color: #999;
  margin-right: 16rpx;
}

.detail-value {
  font-size: 28rpx;
  color: #333;
}

.responses {
  margin-top: 24rpx;
}

.responses-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 16rpx;
  display: block;
}

.response-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.response-name {
  font-size: 28rpx;
  color: #333;
}

.response-status {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

.response-status.pending {
  background: #fff7e6;
  color: #faad14;
}

.response-status.accepted {
  background: #f6ffed;
  color: #52c41a;
}

.response-status.declined {
  background: #fff1f0;
  color: #ff4d4f;
}

.action-bar {
  display: flex;
  gap: 20rpx;
  margin-top: 32rpx;
}

.action-btn {
  flex: 1;
  padding: 24rpx;
  border-radius: 12rpx;
  text-align: center;
  font-size: 30rpx;
}

.action-btn.accept {
  background: #07c160;
  color: #fff;
}

.action-btn.decline {
  background: #f5f5f5;
  color: #666;
}
