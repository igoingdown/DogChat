<view class="container">
  <view class="form card">
    <view class="form-item">
      <text class="label">狗狗头像</text>
      <view class="avatar-upload" bindtap="chooseAvatar">
        <image wx:if="{{avatar}}" class="avatar-preview" src="{{avatar}}" mode="aspectFill"/>
        <view wx:else class="avatar-placeholder">
          <text class="plus">+</text>
        </view>
      </view>
    </view>

    <view class="form-item">
      <text class="label">名字 *</text>
      <input class="input" placeholder="给狗狗起个名字" value="{{name}}" bindinput="onNameInput"/>
    </view>

    <view class="form-item">
      <text class="label">品种</text>
      <input class="input" placeholder="例如：柴犬、金毛" value="{{breed}}" bindinput="onBreedInput"/>
    </view>

    <view class="form-item">
      <text class="label">年龄</text>
      <view class="age-row">
        <input class="age-input" type="number" placeholder="岁" value="{{ageYears}}" bindinput="onAgeYearsInput"/>
        <text class="age-unit">岁</text>
        <input class="age-input" type="number" placeholder="月" value="{{ageMonths}}" bindinput="onAgeMonthsInput"/>
        <text class="age-unit">月</text>
        <input class="age-input" type="number" placeholder="天" value="{{ageDays}}" bindinput="onAgeDaysInput"/>
        <text class="age-unit">天</text>
      </view>
    </view>

    <view class="form-item">
      <text class="label">性别</text>
      <view class="gender-row">
        <view class="gender-option {{gender === '♂' ? 'selected' : ''}}" bindtap="onGenderTap" data-gender="♂">
          <text class="gender-symbol">♂</text>
        </view>
        <view class="gender-option {{gender === '♀' ? 'selected' : ''}}" bindtap="onGenderTap" data-gender="♀">
          <text class="gender-symbol">♀</text>
        </view>
      </view>
    </view>
  </view>

  <view class="save-btn {{name ? 'active' : ''}}" bindtap="save">
    <text>保存</text>
  </view>
</view>
