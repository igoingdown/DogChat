.form-item {
  margin-bottom: 32rpx;
}

.label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
  display: block;
}

.avatar-upload {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.avatar-preview {
  width: 100%;
  height: 100%;
}

.avatar-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
}

.plus {
  font-size: 48rpx;
  color: #ccc;
}

.input {
  background: #f5f5f5;
  padding: 20rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.age-row {
  display: flex;
  align-items: center;
}

.age-input {
  flex: 1;
  background: #f5f5f5;
  padding: 20rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  text-align: center;
}

.age-unit {
  font-size: 26rpx;
  color: #666;
  margin: 0 12rpx;
}

.gender-row {
  display: flex;
  gap: 24rpx;
}

.gender-option {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid transparent;
}

.gender-option.selected {
  border-color: #07c160;
  background: #e8f8ef;
}

.gender-symbol {
  font-size: 48rpx;
}

.save-btn {
  margin-top: 40rpx;
  background: #ccc;
  color: #fff;
  padding: 24rpx;
  border-radius: 12rpx;
  text-align: center;
  font-size: 32rpx;
}

.save-btn.active {
  background: #07c160;
}
