.logo-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx;
}

.logo {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 24rpx;
}

.app-name {
  font-size: 48rpx;
  font-weight: 600;
  color: #07c160;
  margin-bottom: 16rpx;
}

.slogan {
  font-size: 28rpx;
  color: #999;
}

.login-card {
  margin: 0 40rpx;
  padding: 48rpx 40rpx;
  text-align: center;
}

.login-title {
  font-size: 36rpx;
  font-weight: 500;
  color: #333;
  display: block;
  margin-bottom: 16rpx;
}

.login-desc {
  font-size: 26rpx;
  color: #999;
  display: block;
  margin-bottom: 48rpx;
}

.login-btn {
  background: #07c160;
  color: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 32rpx;
  border: none;
  margin-bottom: 24rpx;
}

.login-btn::after {
  border: none;
}

.hint {
  font-size: 22rpx;
  color: #bbb;
}
